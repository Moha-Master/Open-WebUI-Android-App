<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dialog themes for Material Design 3 -->
    <style name="Theme.OpenWebUI.Dialog" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="windowMinWidthMajor">@dimen/abc_dialog_min_width_major</item>
        <item name="windowMinWidthMinor">@dimen/abc_dialog_min_width_minor</item>
    </style>
    
    <!-- Button styles -->
    <style name="Widget.OpenWebUI.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.OpenWebUI.Button</item>
    </style>
    
    <style name="ThemeOverlay.OpenWebUI.Button" parent="">
        <item name="colorPrimary">@color/primary_600</item>
        <item name="colorOnPrimary">@color/on_primary</item>
    </style>
    
    <!-- Text field styles -->
    <style name="Widget.OpenWebUI.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="materialThemeOverlay">@style/ThemeOverlay.OpenWebUI.TextInputEditText</item>
    </style>
    
    <style name="ThemeOverlay.OpenWebUI.TextInputEditText" parent="">
        <item name="colorPrimary">@color/primary_600</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="colorOutline">@color/outline</item>
    </style>
</resources>